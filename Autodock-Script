#  GRID BOX OPTIMIZATION
# ══════════════════════════════════════════════════════════════════════════════

def _parse_fpocket(pocket_dir: Path, pocket_rank: int) -> Tuple[Tuple, Tuple]:
    """Parse fpocket *_info.txt to extract center + size of ranked pocket."""
    info_files = sorted(pocket_dir.glob("*_info.txt"))
    if not info_files:
        raise FileNotFoundError(f"No fpocket info files in {pocket_dir}")

    # fpocket numbers pockets 1-indexed by druggability score
    target_idx = pocket_rank - 1
    info_file = info_files[0]  # single info file with all pockets

    pockets: List[Dict] = []
    current: Dict = {}
    with info_file.open() as fh:
        for line in fh:
            line = line.strip()
            m = re.match(r"Pocket (\d+) :", line)
            if m:
                if current:
                    pockets.append(current)
                current = {"rank": int(m.group(1))}
            elif ":" in line and current:
                key, _, val = line.partition(":")
                current[key.strip()] = val.strip()
    if current:
        pockets.append(current)

    if target_idx >= len(pockets):
        log.warning("Pocket %d not found; using pocket 1", pocket_rank)
        target_idx = 0

    p = pockets[target_idx]
    try:
        cx = float(p.get("x_barycenter", p.get("Barycenter x", 0)))
        cy = float(p.get("y_barycenter", p.get("Barycenter y", 0)))
        cz = float(p.get("z_barycenter", p.get("Barycenter z", 0)))
    except (ValueError, KeyError):
        raise ValueError(f"Cannot parse barycenter from fpocket pocket {pocket_rank}")

    # Estimate box size from pocket volume: V = (4/3)π r³  → r = (3V/4π)^(1/3)
    try:
        vol = float(p.get("Volume", p.get("Real volume", 500)))
        r   = (3 * vol / (4 * math.pi)) ** (1 / 3)
        size = max(15.0, 2 * r + GRID_PADDING)
    except (ValueError, KeyError):
        size = 22.0

    center = (round(cx, 3), round(cy, 3), round(cz, 3))
    box    = (round(size, 1), round(size, 1), round(size, 1))
    log.info("    fpocket pocket %d: center=%s  size=%s Å", pocket_rank, center, box)
    return center, box


def optimize_grid_fpocket(receptor_pdb: Path, pocket_rank: int,
                          work_dir: Path) -> Tuple[Tuple, Tuple]:
    """Run fpocket on the receptor and return (center, size) for pocket_rank."""
    if not _is_cmd("fpocket"):
        raise RuntimeError(
            "fpocket not found. Install: sudo apt-get install fpocket  "
            "or  pip install fpocket  (check fpocket repo for RPM)"
        )

    out_dir = work_dir / f"{receptor_pdb.stem}_out"
    if not out_dir.exists():
        log.info("    Running fpocket on %s …", receptor_pdb.name)
        _run(["fpocket", "-f", str(receptor_pdb)], cwd=work_dir)
    else:
        log.info("    fpocket output cached: %s", out_dir.name)

    return _parse_fpocket(out_dir, pocket_rank)


def _pdbqt_centroid(pdbqt_path: Path) -> Tuple[float, float, float]:
    """Geometric centroid of all ATOM/HETATM coordinates in a PDBQT/PDB file."""
    xs, ys, zs = [], [], []
    with pdbqt_path.open() as fh:
        for line in fh:
            if line.startswith(("ATOM", "HETATM")):
                try:
                    xs.append(float(line[30:38]))
                    ys.append(float(line[38:46]))
                    zs.append(float(line[46:54]))
                except ValueError:
                    continue
    if not xs:
        raise ValueError(f"No atom coordinates found in {pdbqt_path}")
    span = lambda v: max(v) - min(v)
    cx = sum(xs) / len(xs)
    cy = sum(ys) / len(ys)
    cz = sum(zs) / len(zs)
    size = max(span(xs), span(ys), span(zs)) + 2 * GRID_PADDING
    size = max(15.0, size)
    return (round(cx, 3), round(cy, 3), round(cz, 3)), (round(size, 1),) * 3


def resolve_grid(receptor_pdb: Path, work_dir: Path,
                 cli_pocket: Optional[int] = None) -> Tuple[Tuple, Tuple]:
    """
    Determine grid center and size according to GRID_MODE.
    Returns (center_xyz, size_xyz).
    """
    mode = GRID_MODE
    if cli_pocket is not None:
        mode = "fpocket"

    if mode == "manual":
        log.info("── Grid box: manual  center=%s  size=%s ──",
                 GRID_CENTER, GRID_SIZE)
        return GRID_CENTER, GRID_SIZE

    if mode == "fpocket":
        rank = cli_pocket or FPOCKET_POCKET
        log.info("── Grid box: fpocket (pocket #%d) ──", rank)
        return optimize_grid_fpocket(receptor_pdb, rank, work_dir)

    if mode == "reference":
        ref = Path(REFERENCE_LIGAND)
        if not ref.exists():
            log.warning("Reference ligand %s not found — falling back to manual", ref)
            return GRID_CENTER, GRID_SIZE
        log.info("── Grid box: reference ligand %s ──", ref.name)
        center, size = _pdbqt_centroid(ref)
        log.info("    center=%s  size=%s Å", center, size)
        return center, size

    log.warning("Unknown GRID_MODE '%s' — using manual", mode)
    return GRID_CENTER, GRID_SIZE


# ══════════════════════════════════════════════════════════════════════════════
#  LIGAND PREPARATION  (charge assignment + PDBQT)
# ══════════════════════════════════════════════════════════════════════════════

def _am1bcc_charges(mol_path: Path, out_sdf: Path) -> bool:
    """
    Try to assign AM1-BCC charges via antechamber (AmberTools).
    Returns True on success.
    """
    if not _is_cmd("antechamber"):
        return False
    mol2_tmp = out_sdf.with_suffix(".mol2")
    r = _run([
        "antechamber",
        "-i",  str(mol_path),
        "-fi", mol_path.suffix.lstrip(".").lower() or "mol2",
        "-o",  str(mol2_tmp),
        "-fo", "mol2",
        "-c",  "bcc",
        "-s",  "2",
        "-nc", "0",
    ], check=False, capture=True)
    if r.returncode == 0 and mol2_tmp.exists():
        shutil.move(str(mol2_tmp), str(out_sdf))
        return True
    log.debug("antechamber failed: %s", r.stderr[:200])
    return False


def _smiles_to_pdbqt_meeko(smiles: str, name: str, out_path: Path,
                            charge_method: str) -> None:
    from rdkit import Chem
    from rdkit.Chem import AllChem
    from meeko import MoleculePreparation

    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        raise ValueError(f"Invalid SMILES: {smiles!r}")
    mol = Chem.AddHs(mol)
    mol.SetProp("_Name", name)

    p = AllChem.ETKDGv3()
    p.randomSeed = 42
    if AllChem.EmbedMolecule(mol, p) == -1:
        AllChem.EmbedMolecule(mol, AllChem.ETKDG())
    AllChem.MMFFOptimizeMolecule(mol)

    # AM1-BCC: write to SDF, run antechamber, reload
    if charge_method in ("am1bcc", "auto"):
        with tempfile.TemporaryDirectory() as tmp:
            tmp_sdf = Path(tmp) / f"{name}.sdf"
            w = Chem.SDWriter(str(tmp_sdf))
            w.write(mol)
            w.close()
            if _am1bcc_charges(tmp_sdf, tmp_sdf):
                mol = Chem.MolFromMolFile(str(tmp_sdf), removeHs=False)
                log.debug("    AM1-BCC charges applied to %s", name)
            elif charge_method == "am1bcc":
                raise RuntimeError("AM1-BCC requested but antechamber not available")
            else:
                log.debug("    AM1-BCC unavailable — using Gasteiger for %s", name)

    preparator = MoleculePreparation()
    mol_setups = preparator.prepare(mol)
    pdbqt_str, is_ok, err = MoleculePreparation.write_pdbqt_string(
        mol_setups[0], bad_charge_ok=True
    )
    if not is_ok:
        log.warning("    Meeko note for %s: %s", name, err)
    out_path.write_text(pdbqt_str)


def _file_to_pdbqt_obabel(src: Path, out_path: Path, charge_method: str) -> None:
    method = "gasteiger"
    if charge_method in ("am1bcc", "auto") and _is_cmd("antechamber"):
        with tempfile.TemporaryDirectory() as tmp:
            charged = Path(tmp) / src.name
            if _am1bcc_charges(src, charged):
                src = charged
                log.debug("    AM1-BCC charges applied to %s", src.name)
    _run([
        "obabel", str(src),
        "-O", str(out_path),
        "--gen3d",
        "--partialcharge", method,
        "-p", str(RECEPTOR_PH),
    ])


def prepare_ligand(ligand_spec: str, index: int, name_hint: str,
                   out_dir: Path) -> Tuple[str, Path]:
    """Prepare one ligand → PDBQT. Idempotent."""
    charge_method = LIGAND_CHARGE_METHOD

    if _is_smiles(ligand_spec):
        name = name_hint or f"smiles_{index:03d}"
        pdbqt_path = out_dir / f"{name}.pdbqt"
        if pdbqt_path.exists() and pdbqt_path.stat().st_size > 0:
            log.info("    [cached] %s", pdbqt_path.name)
            return name, pdbqt_path
        log.info("    Preparing SMILES '%s' (charge=%s) …", name, charge_method)
        _smiles_to_pdbqt_meeko(ligand_spec, name, pdbqt_path, charge_method)
    else:
        src = Path(ligand_spec)
        if not src.exists():
            raise FileNotFoundError(f"Ligand file not found: {src}")
        name = name_hint or src.stem
        pdbqt_path = out_dir / f"{name}.pdbqt"
        if (pdbqt_path.exists() and pdbqt_path.stat().st_size > 0
                and pdbqt_path.stat().st_mtime >= src.stat().st_mtime):
            log.info("    [cached] %s", pdbqt_path.name)
            return name, pdbqt_path
        log.info("    Preparing '%s' (%s, charge=%s) …",
                 name, src.suffix, charge_method)
        _file_to_pdbqt_obabel(src, pdbqt_path, charge_method)

    if not pdbqt_path.exists() or pdbqt_path.stat().st_size == 0:
        raise RuntimeError(f"Ligand PDBQT empty or missing: {pdbqt_path}")
    return name, pdbqt_path


# ══════════════════════════════════════════════════════════════════════════════
#  DOCKING ENGINES  (Python API → CLI fallback)
# ══════════════════════════════════════════════════════════════════════════════

def _dock_python_api(rigid_pdbqt: Path, flex_pdbqt: Optional[Path],
                     ligand_pdbqt: Path, out_pdbqt: Path, log_path: Path,
                     center: Tuple, size: Tuple, exhaustiveness: int,
                     seed: int) -> str:
    from vina import Vina

    v = Vina(sf_name="vina", cpu=CPU_CORES or 0, verbosity=0, seed=seed)
    v.set_receptor(str(rigid_pdbqt), str(flex_pdbqt) if flex_pdbqt else "")
    v.set_ligand_from_file(str(ligand_pdbqt))
    v.compute_vina_maps(center=list(center), box_size=list(size))
    v.dock(exhaustiveness=exhaustiveness, n_poses=NUM_MODES)
    v.write_poses(str(out_pdbqt), n_poses=NUM_MODES, overwrite=True)

    energies = v.energies(n_poses=NUM_MODES)
    lines = ["mode | affinity (kcal/mol) | rmsd lb | rmsd ub"]
    for i, e in enumerate(energies, 1):
        lines.append(f"  {i:2d}  |  {e[0]:+.3f}  |  {e[1]:.3f}  |  {e[2]:.3f}")
    raw = "\n".join(lines)
    log_path.write_text(raw)
    return raw


def _dock_cli(rigid_pdbqt: Path, flex_pdbqt: Optional[Path],
              ligand_pdbqt: Path, out_pdbqt: Path, log_path: Path,
              center: Tuple, size: Tuple, exhaustiveness: int,
              seed: int) -> str:
    if not _is_cmd("vina"):
        raise RuntimeError("'vina' binary not found and Python API failed.")
    cmd = [
        "vina",
        "--receptor",     str(rigid_pdbqt),
        "--ligand",       str(ligand_pdbqt),
        "--out",          str(out_pdbqt),
        "--log",          str(log_path),
        "--center_x",     str(center[0]),
        "--center_y",     str(center[1]),
        "--center_z",     str(center[2]),
        "--size_x",       str(size[0]),
        "--size_y",       str(size[1]),
        "--size_z",       str(size[2]),
        "--exhaustiveness", str(exhaustiveness),
        "--num_modes",    str(NUM_MODES),
        "--energy_range", str(ENERGY_RANGE),
        "--seed",         str(seed),
    ]
    if flex_pdbqt and flex_pdbqt.exists() and flex_pdbqt.stat().st_size > 0:
        cmd += ["--flex", str(flex_pdbqt)]
    if CPU_CORES:
        cmd += ["--cpu", str(CPU_CORES)]
    r = _run(cmd, capture=True)
    raw = r.stdout + r.stderr
    log_path.write_text(raw)
    return raw


def single_dock(rigid_pdbqt: Path, flex_pdbqt: Optional[Path],
                ligand_pdbqt: Path, out_pdbqt: Path, log_path: Path,
                center: Tuple, size: Tuple,
                exhaustiveness: int, seed: int) -> str:
    """One docking call. Tries Python API first, falls back to CLI."""
    try:
        return _dock_python_api(rigid_pdbqt, flex_pdbqt, ligand_pdbqt,
                                out_pdbqt, log_path, center, size,
                                exhaustiveness, seed)
    except Exception as e:
        log.debug("  Python API error (%s) — using CLI", e)
        return _dock_cli(rigid_pdbqt, flex_pdbqt, ligand_pdbqt,
                         out_pdbqt, log_path, center, size,
                         exhaustiveness, seed)


# ══════════════════════════════════════════════════════════════════════════════
#  MULTIPLE RUNS  +  EXHAUSTIVENESS LADDER
# ══════════════════════════════════════════════════════════════════════════════

def _parse_modes(raw_log: str) -> List[Dict]:
    modes = []
    pattern = re.compile(
        r"^\s*(\d+)\s+([+-]?\d+\.\d+)\s+([+-]?\d+\.\d+)\s+([+-]?\d+\.\d+)",
        re.MULTILINE,
    )
    for m in pattern.finditer(raw_log):
        modes.append({
            "mode":     int(m.group(1)),
            "affinity": float(m.group(2)),
            "rmsd_lb":  float(m.group(3)),
            "rmsd_ub":  float(m.group(4)),
        })
    return modes


def multi_run_dock(rigid_pdbqt: Path, flex_pdbqt: Optional[Path],
                   ligand_pdbqt: Path, name: str, poses_dir: Path,
                   logs_dir: Path, center: Tuple, size: Tuple) -> Dict:
    """
    Run NUM_RUNS independent docking jobs with different random seeds.
    Aggregate all modes, take best-of-N by affinity.
    Optionally run exhaustiveness ladder before the seed sweep.
    Returns a result dict.
    """
    # ── Exhaustiveness ladder (optional) ────────────────────────────────────
    chosen_exhaustiveness = EXHAUSTIVENESS
    if LADDER_ENABLED and EXHAUSTIVENESS_LADDER:
        log.info("    Exhaustiveness ladder: %s", EXHAUSTIVENESS_LADDER)
        prev_best = None
        for exh in sorted(EXHAUSTIVENESS_LADDER):
            lad_out = poses_dir / f"{name}_ladder{exh}.pdbqt"
            lad_log = logs_dir  / f"{name}_ladder{exh}.log"
            if lad_out.exists() and lad_out.stat().st_size > 0:
                raw = lad_log.read_text() if lad_log.exists() else ""
            else:
                log.info("      exh=%d …", exh)
                raw = single_dock(rigid_pdbqt, flex_pdbqt, ligand_pdbqt,
                                  lad_out, lad_log, center, size, exh, seed=42)
            modes = _parse_modes(raw)
            best = modes[0]["affinity"] if modes else None
            if best is not None:
                log.info("      exh=%-3d  best ΔG = %.3f kcal/mol", exh, best)
                if prev_best is not None and abs(best - prev_best) < CONVERGENCE_THRESHOLD:
                    log.info("      Converged at exhaustiveness=%d (Δ=%.3f < %.3f)",
                             exh, abs(best - prev_best), CONVERGENCE_THRESHOLD)
                    chosen_exhaustiveness = exh
                    break
                prev_best = best
                chosen_exhaustiveness = exh
        log.info("    Selected exhaustiveness: %d", chosen_exhaustiveness)

    # ── Seed sweep ───────────────────────────────────────────────────────────
    all_modes: List[Dict] = []
    seeds = [42 + i * 137 for i in range(NUM_RUNS)]   # deterministic seeds

    for run_idx, seed in enumerate(seeds, 1):
        out_pdbqt = poses_dir / f"{name}_run{run_idx}.pdbqt"
        log_path  = logs_dir  / f"{name}_run{run_idx}.log"

        if out_pdbqt.exists() and out_pdbqt.stat().st_size > 0:
            log.info("    [cached] run %d/%d (seed=%d)", run_idx, NUM_RUNS, seed)
            raw = log_path.read_text() if log_path.exists() else ""
        else:
            log.info("    Run %d/%d  seed=%-6d  exh=%d …",
                     run_idx, NUM_RUNS, seed, chosen_exhaustiveness)
            raw = single_dock(rigid_pdbqt, flex_pdbqt, ligand_pdbqt,
                              out_pdbqt, log_path, center, size,
                              chosen_exhaustiveness, seed)

        modes = _parse_modes(raw)
        for m in modes:
            m["run"]  = run_idx
            m["seed"] = seed
        all_modes.extend(modes)

    if not all_modes:
        return {
            "name": name, "best_affinity": float("nan"),
            "ki_uM": float("nan"), "classification": "ERROR",
            "rmsd_lb": float("nan"), "rmsd_ub": float("nan"),
            "num_modes": 0, "all_modes": [], "runs": NUM_RUNS,
            "exhaustiveness_used": chosen_exhaustiveness,
            "poses_dir": str(poses_dir),
        }

    # Sort all collected modes by affinity (most negative = best)
    all_modes.sort(key=lambda m: m["affinity"])
    best = all_modes[0]

    # ── RMSD cluster — count how many runs agree on the best pose ────────────
    cluster_count = sum(
        1 for m in all_modes
        if abs(m["affinity"] - best["affinity"]) < RMSD_CLUSTER_CUTOFF / 2
    )
    reproducibility = round(cluster_count / len(all_modes) * 100, 1)

    affinity = best["affinity"]
    ki       = _estimate_ki(affinity)
    quality  = classify_affinity(affinity)

    log.info("    Best: ΔG=%.3f kcal/mol  Ki≈%.4f µM  [%s]  Reproducibility=%.0f%%",
             affinity, ki, quality, reproducibility)

    return {
        "name":                name,
        "best_affinity":       affinity,
        "ki_uM":               ki,
        "classification":      quality,
        "rmsd_lb":             best["rmsd_lb"],
        "rmsd_ub":             best["rmsd_ub"],
        "num_modes":           len(all_modes),
        "runs":                NUM_RUNS,
        "exhaustiveness_used": chosen_exhaustiveness,
        "reproducibility_pct": reproducibility,
        "all_modes":           all_modes,
        "poses_dir":           str(poses_dir),
        "best_run":            best["run"],
        "best_seed":           best["seed"],
    }


# ══════════════════════════════════════════════════════════════════════════════
#  SCORING HELPERS
# ══════════════════════════════════════════════════════════════════════════════

def _estimate_ki(affinity_kcal: float, temp_K: float = 298.15) -> float:
    R = 1.987e-3   # kcal/(mol·K)
    ki_molar = math.exp(affinity_kcal / (R * temp_K))
    return ki_molar * 1e6   # µM


def classify_affinity(affinity: float) -> str:
    if affinity <= -10.0: return "Excellent"
    if affinity <= -8.0:  return "Very Good"
    if affinity <= -6.0:  return "Good"
    if affinity <= -4.0:  return "Moderate"
    return "Weak"


