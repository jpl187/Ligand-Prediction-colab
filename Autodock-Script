#  PROTONATION & CHARGE ASSIGNMENT — RECEPTOR
# ══════════════════════════════════════════════════════════════════════════════

def protonate_receptor(pdb_path: Path, out_dir: Path) -> Path:
    """
    Stage 1 of receptor prep: add hydrogens at the target pH.

    Priority:
      1. pdb2pqr (CLI) with PROPKA — full pH-aware titration of all residues
      2. obabel -p flag — fast but pH-unaware (no pKa calculation)

    Returns path to a protonated PDB (not PDBQT yet).
    """
    protonated_pdb = out_dir / "receptor_protonated.pdb"

    if (protonated_pdb.exists()
            and protonated_pdb.stat().st_mtime >= pdb_path.stat().st_mtime):
        log.info("    Protonated receptor cached: %s", protonated_pdb.name)
        return protonated_pdb

    # ── Try pdb2pqr (PROPKA) ──────────────────────────────────────────────
    if _is_cmd("pdb2pqr") or _is_cmd("pdb2pqr30"):
        cmd_name = "pdb2pqr30" if _is_cmd("pdb2pqr30") else "pdb2pqr"
        pqr_path = out_dir / "receptor.pqr"
        log.info("    pdb2pqr (PROPKA, pH %.1f, FF=%s) …", RECEPTOR_PH, RECEPTOR_FF)
        r = _run([
            cmd_name,
            "--ff",        RECEPTOR_FF,
            "--with-ph",   str(RECEPTOR_PH),
            "--titration-state-method", "propka",
            "--pdb-output", str(protonated_pdb),
            str(pdb_path),
            str(pqr_path),
        ], check=False, capture=True)
        if r.returncode == 0 and protonated_pdb.exists():
            log.info("    Protonation done via pdb2pqr+PROPKA")
            return protonated_pdb
        else:
            log.warning("    pdb2pqr failed (%s) — falling back to obabel",
                        r.stderr.strip()[:120])

    # ── Fallback: obabel ─────────────────────────────────────────────────
    log.info("    Protonation via obabel (pH %.1f) …", RECEPTOR_PH)
    _run([
        "obabel", str(pdb_path),
        "-O", str(protonated_pdb),
        "-p", str(RECEPTOR_PH),
        "--title", "receptor",
    ])
    return protonated_pdb


def assign_receptor_charges_and_convert(protonated_pdb: Path, out_dir: Path) -> Path:
    """
    Stage 2 of receptor prep: assign Gasteiger charges and convert to PDBQT.
    Returns path to receptor PDBQT (rigid, no flex split yet).
    """
    pdbqt_path = out_dir / "receptor_full.pdbqt"

    if (pdbqt_path.exists()
            and pdbqt_path.stat().st_mtime >= protonated_pdb.stat().st_mtime):
        log.info("    Receptor PDBQT cached: %s", pdbqt_path.name)
        return pdbqt_path

    log.info("    Assigning Gasteiger charges → PDBQT …")
    _run([
        "obabel", str(protonated_pdb),
        "-O", str(pdbqt_path),
        "--partialcharge", "gasteiger",
        "-d",   # merge nonpolar H
        "--title", "receptor",
    ])

    if not pdbqt_path.exists() or pdbqt_path.stat().st_size == 0:
        raise RuntimeError(f"Receptor PDBQT conversion failed: {pdbqt_path}")

    return pdbqt_path


# ══════════════════════════════════════════════════════════════════════════════
#  FLEXIBLE-RESIDUE SPLITTING
# ══════════════════════════════════════════════════════════════════════════════

def _meeko_flex_split(full_pdbqt: Path, flex_residues: List[str],
                      out_dir: Path) -> Tuple[Path, Path]:
    """
    Use meeko's mk_prepare_receptor CLI to produce rigid + flex PDBQTs.
    flex_residues format: ["A:TYR:50", "A:PHE:103"]
    """
    rigid_path = out_dir / "receptor_rigid.pdbqt"
    flex_path  = out_dir / "receptor_flex.pdbqt"

    if (rigid_path.exists() and flex_path.exists()
            and rigid_path.stat().st_size > 0 and flex_path.stat().st_size > 0):
        log.info("    Rigid/flex split cached")
        return rigid_path, flex_path

    # meeko format: "A:TYR:50_A:PHE:103"
    flex_str  = "_".join(f.replace(":", ":") for f in flex_residues)
    base_name = str(out_dir / "receptor")

    mk_cmd = "mk_prepare_receptor.py"
    if not _is_cmd(mk_cmd):
        # Try as a module
        mk_cmd = None

    protonated_pdb = out_dir / "receptor_protonated.pdb"
    if not protonated_pdb.exists():
        protonated_pdb = full_pdbqt  # fallback

    if mk_cmd:
        r = _run([
            mk_cmd,
            "--pdb",     str(protonated_pdb),
            "--flexres", flex_str,
            "-o",        base_name,
        ], check=False, capture=True)
        if r.returncode == 0:
            # meeko output filenames
            for candidate in (
                out_dir / "receptor_rigid.pdbqt",
                out_dir / "receptor_flex.pdbqt",
            ):
                if not candidate.exists():
                    # try alternate naming
                    for f in out_dir.glob("*.pdbqt"):
                        if "rigid" in f.stem:
                            f.rename(rigid_path)
                        elif "flex" in f.stem:
                            f.rename(flex_path)
            if rigid_path.exists() and flex_path.exists():
                log.info("    Rigid/flex split done via mk_prepare_receptor")
                return rigid_path, flex_path
        log.warning("    mk_prepare_receptor failed — using Python PDBQT splitter")

    # ── Python PDBQT splitter fallback ──────────────────────────────────
    log.info("    Splitting PDBQT with built-in parser …")
    _split_pdbqt_flex(full_pdbqt, flex_residues, rigid_path, flex_path)
    return rigid_path, flex_path


def _split_pdbqt_flex(full_pdbqt: Path, flex_residues: List[str],
                      rigid_out: Path, flex_out: Path) -> None:
    """
    Minimal PDBQT splitter: extracts side-chain atoms of listed residues
    into a flex PDBQT block; backbone + other residues go to rigid.

    NOTE: This produces a simplified flex file (no BRANCH/ENDBRANCH tree).
    For production runs with many flexible residues, prefer meeko or ADT.
    """
    # Parse flex residue specs
    flex_keys: set = set()
    for spec in flex_residues:
        parts = spec.split(":")
        if len(parts) == 3:
            chain, resname, resnum = parts
            flex_keys.add((chain.strip(), resname.strip().upper(), resnum.strip()))

    backbone_atoms = {"N", "CA", "C", "O", "OXT", "H", "HA"}

    rigid_lines: List[str] = []
    flex_blocks: Dict[tuple, List[str]] = {k: [] for k in flex_keys}

    with full_pdbqt.open() as fh:
        for line in fh:
            if line.startswith(("ATOM", "HETATM")):
                chain   = line[21].strip()
                resname = line[17:20].strip().upper()
                resnum  = line[22:26].strip()
                atom    = line[12:16].strip()
                key     = (chain, resname, resnum)
                if key in flex_keys and atom not in backbone_atoms:
                    flex_blocks[key].append(line)
                    continue
            rigid_lines.append(line)

    rigid_out.write_text("".join(rigid_lines))

    flex_parts: List[str] = []
    for key, lines in flex_blocks.items():
        if not lines:
            continue
        chain, resname, resnum = key
        flex_parts.append(f"BEGIN_RES {resname} {chain} {resnum}\n")
        flex_parts.extend(lines)
        flex_parts.append(f"END_RES {resname} {chain} {resnum}\n")

    if flex_parts:
        flex_out.write_text("".join(flex_parts))
    else:
        log.warning("    No flex atoms extracted — check FLEXIBLE_RESIDUES format")
        # Write empty-ish file so Vina doesn't complain
        flex_out.write_text("")

    log.info("    Rigid: %d lines | Flex: %d blocks",
             len(rigid_lines), len(flex_blocks))


def prepare_receptor_full(pdb_path: Path, out_dir: Path) -> Tuple[Path, Optional[Path]]:
    """
    Full receptor preparation pipeline.
    Returns (rigid_pdbqt, flex_pdbqt_or_None).
    """
    log.info("── Receptor preparation ──")

    # 1. Protonation
    protonated = protonate_receptor(pdb_path, out_dir)

    # 2. Charge assignment + PDBQT
    full_pdbqt = assign_receptor_charges_and_convert(protonated, out_dir)

    # 3. Flexible residue split
    if FLEXIBLE_RESIDUES:
        log.info("    Flexible residues: %s", ", ".join(FLEXIBLE_RESIDUES))
        rigid_pdbqt, flex_pdbqt = _meeko_flex_split(full_pdbqt, FLEXIBLE_RESIDUES, out_dir)
        return rigid_pdbqt, flex_pdbqt
    else:
        log.info("    No flexible residues — rigid-only receptor")
        rigid_pdbqt = out_dir / "receptor_rigid.pdbqt"
        if not rigid_pdbqt.exists():
            shutil.copy(full_pdbqt, rigid_pdbqt)
        return rigid_pdbqt, None


