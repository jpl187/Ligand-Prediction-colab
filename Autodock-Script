def _pip_installed(import_name: str) -> bool:
    try:
        __import__(import_name)
        return True
    except ImportError:
        return False


def install_system_deps(os_family: str) -> None:
    log.info("── System dependencies (%s) ──", os_family)
    if os_family == "debian":
        _run(["sudo", "apt-get", "update", "-qq"])
        # Core packages only (skip large optional ones that may not exist)
        safe_pkgs = ["python3-pip", "openbabel", "python3-openbabel", "pdb2pqr"]
        for pkg in safe_pkgs:
            r = _run(["dpkg", "-s", pkg], check=False, capture=True)
            if r.returncode == 0:
                log.info("  [ok] %-30s already installed", pkg)
            else:
                log.info("  [+]  installing %-25s …", pkg)
                _run(["sudo", "apt-get", "install", "-y", "-qq", pkg], check=False)
        # fpocket separately (may not be in default repos on all versions)
        r = _run(["dpkg", "-s", "fpocket"], check=False, capture=True)
        if r.returncode != 0:
            log.info("  [~]  fpocket not in apt — will use pip/source if needed")

    elif os_family == "rpm":
        pm = "dnf" if _is_cmd("dnf") else "yum"
        safe_pkgs = ["python3-pip", "openbabel", "openbabel-python"]
        for pkg in safe_pkgs:
            r = _run([pm, "list", "installed", pkg], check=False, capture=True)
            if r.returncode == 0:
                log.info("  [ok] %-30s already installed", pkg)
            else:
                log.info("  [+]  installing %-25s …", pkg)
                _run(["sudo", pm, "install", "-y", pkg], check=False)
    else:
        log.warning("Unknown OS — skipping system package install.")


def install_python_deps() -> None:
    log.info("── Python dependencies ──")
    for imp, pkg in _PIP_PKGS.items():
        if _pip_installed(imp):
            log.info("  [ok] %-20s already installed", pkg.split(">=")[0])
        else:
            log.info("  [+]  pip install %-20s …", pkg)
            _run([sys.executable, "-m", "pip", "install", "--quiet", pkg])


