def detect_os() -> str:
    if Path("/etc/debian_version").exists():
        return "debian"
    if Path("/etc/fedora-release").exists() or Path("/etc/redhat-release").exists():
        return "rpm"
    try:
        txt = Path("/etc/os-release").read_text()
        if any(k in txt.lower() for k in ("ubuntu", "debian", "mint", "pop")):
            return "debian"
        if any(k in txt.lower() for k in ("fedora", "rhel", "centos", "rocky", "alma")):
            return "rpm"
    except FileNotFoundError:
        pass
    return "unknown"


