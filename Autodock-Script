def write_summary(results: List[Dict], out_dir: Path,
                  center: Tuple, size: Tuple) -> None:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # ── CSV ─────────────────────────────────────────────────────────────────
    csv_path = out_dir / "summary.csv"
    fields   = [
        "ligand", "best_affinity_kcal_mol", "ki_uM", "classification",
        "best_rmsd_lb_A", "best_rmsd_ub_A", "total_modes",
        "runs", "exhaustiveness_used", "reproducibility_pct",
        "best_run", "best_seed", "poses_dir",
    ]
    with csv_path.open("w", newline="") as fh:
        w = csv.DictWriter(fh, fieldnames=fields, extrasaction="ignore")
        w.writeheader()
        for r in results:
            w.writerow({
                "ligand":                  r["name"],
                "best_affinity_kcal_mol":  r.get("best_affinity", ""),
                "ki_uM":                   f"{r['ki_uM']:.4f}" if r.get("ki_uM") == r.get("ki_uM") else "",
                "classification":          r.get("classification", ""),
                "best_rmsd_lb_A":          r.get("rmsd_lb", ""),
                "best_rmsd_ub_A":          r.get("rmsd_ub", ""),
                "total_modes":             r.get("num_modes", 0),
                "runs":                    r.get("runs", 1),
                "exhaustiveness_used":     r.get("exhaustiveness_used", EXHAUSTIVENESS),
                "reproducibility_pct":     r.get("reproducibility_pct", ""),
                "best_run":                r.get("best_run", 1),
                "best_seed":               r.get("best_seed", 42),
                "poses_dir":               r.get("poses_dir", ""),
            })

    # ── JSON ─────────────────────────────────────────────────────────────────
    json_path = out_dir / "summary.json"
    meta = {
        "generated":    timestamp,
        "protein":      PROTEIN_FILE,
        "grid_mode":    GRID_MODE,
        "grid_center":  center,
        "grid_size":    size,
        "receptor_ph":  RECEPTOR_PH,
        "receptor_ff":  RECEPTOR_FF,
        "charge_method":LIGAND_CHARGE_METHOD,
        "flexible_residues": FLEXIBLE_RESIDUES,
        "num_runs":     NUM_RUNS,
        "exhaustiveness": EXHAUSTIVENESS,
        "ladder_enabled": LADDER_ENABLED,
    }
    json_path.write_text(json.dumps({"meta": meta, "results": results}, indent=2))

    # ── Human-readable TXT ───────────────────────────────────────────────────
    txt_path = out_dir / "summary.txt"
    sep      = "═" * 90
    sub      = "─" * 90
    hdr = (f"{'Ligand':<22} {'ΔG':>8} {'Ki(µM)':>10} {'Quality':<11}"
           f" {'RMSD lb':>7} {'RMSD ub':>7} {'Modes':>6}"
           f" {'Repro%':>7} {'Best Run':>9}")

    sorted_results = sorted(
        [r for r in results if not math.isnan(r.get("best_affinity", float("nan")))],
        key=lambda r: r["best_affinity"]
    ) + [r for r in results if math.isnan(r.get("best_affinity", float("nan")))]

    lines = [
        sep,
        "  AutoDock Vina — Enhanced Docking Summary",
        sep,
        f"  Generated          : {timestamp}",
        f"  Receptor           : {PROTEIN_FILE}",
        f"  Protonation        : pdb2pqr + PROPKA  pH={RECEPTOR_PH}  FF={RECEPTOR_FF}",
        f"  Charge method      : {LIGAND_CHARGE_METHOD}",
        f"  Grid mode          : {GRID_MODE}  center={center}  size={size}",
        f"  Flexible residues  : {', '.join(FLEXIBLE_RESIDUES) or 'none (rigid)'}",
        f"  Runs per ligand    : {NUM_RUNS}  (seed sweep, best-of-N)",
        f"  Exhaustiveness     : {EXHAUSTIVENESS}"
        + (f"  [ladder: {EXHAUSTIVENESS_LADDER}]" if LADDER_ENABLED else ""),
        sub,
        hdr,
        sub,
    ]

    for r in sorted_results:
        aff  = f"{r['best_affinity']:.3f}" if not math.isnan(r.get("best_affinity", float("nan"))) else "  ERROR"
        ki   = f"{r['ki_uM']:.4f}"         if not math.isnan(r.get("ki_uM", float("nan")))         else "  N/A"
        repro= f"{r.get('reproducibility_pct', ''):>6.1f}" if r.get("reproducibility_pct") else "    N/A"
        lines.append(
            f"  {r['name']:<20} {aff:>8} {ki:>10} {r.get('classification',''):11}"
            f" {r.get('rmsd_lb', 0):>7.3f} {r.get('rmsd_ub', 0):>7.3f}"
            f" {r.get('num_modes', 0):>6} {repro:>7}%"
            f" {str(r.get('best_run', ''))+'/'+ str(r.get('runs',1)):>9}"
        )

    lines += [
        sep,
        "  Sorted by ΔG (kcal/mol) — most negative = strongest predicted binding.",
        "  Ki estimated via ΔG = RT·ln(Ki) at 298.15 K.",
        "  Reproducibility = % of all poses within RMSD_CLUSTER_CUTOFF/2 of best.",
        "  Per-ligand PDBQT poses and Vina logs are in ligand sub-directories.",
        sep,
    ]
    txt_path.write_text("\n".join(lines) + "\n")

    log.info("Summaries written:")
    for p in (csv_path, json_path, txt_path):
        log.info("  %s", p)


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(
        description="AutoDock Vina Enhanced Pipeline",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--skip-install", action="store_true",
                        help="Skip all system/Python package installation")
    parser.add_argument("--pocket", type=int, default=None,
                        help="Override GRID_MODE=fpocket and use pocket #N")
    parser.add_argument("--debug", action="store_true")
    args = parser.parse_args(argv)

    if args.debug:
        logging.getLogger().setLevel(logging.DEBUG)

    log.info("╔═══════════════════════════════════════════════════╗")
    log.info("║  AutoDock Vina — Enhanced Docking Pipeline        ║")
    log.info("╚═══════════════════════════════════════════════════╝")

    # ── Preflight ──────────────────────────────────────────────────────────
    protein_path = Path(PROTEIN_FILE)
    if not protein_path.exists():
        log.error("Receptor PDB not found: %s", protein_path)
        return 1
    if not LIGANDS:
        log.error("LIGANDS list is empty.")
        return 1

    names = list(SMILES_NAMES) + [""] * max(0, len(LIGANDS) - len(SMILES_NAMES))

    # ── Output directories ─────────────────────────────────────────────────
    out_dir     = Path(OUTPUT_DIR)
    rec_dir     = out_dir / "receptor"
    ligands_dir = out_dir / "ligands"
    summary_dir = out_dir / "summary"

    for d in (out_dir, rec_dir, ligands_dir, summary_dir):
        d.mkdir(parents=True, exist_ok=True)

    log.info("Output: %s", out_dir.resolve())

    # ── 1. Install dependencies ────────────────────────────────────────────
    if not args.skip_install:
        os_family = detect_os()
        log.info("OS family: %s", os_family)
        install_system_deps(os_family)
        install_python_deps()
    else:
        log.info("Skipping dependency install (--skip-install)")

    # ── 2. Receptor: protonation + charge + optional flex split ───────────
    rigid_pdbqt, flex_pdbqt = prepare_receptor_full(protein_path, rec_dir)

    # ── 3. Grid box resolution ─────────────────────────────────────────────
    center, size = resolve_grid(protein_path, rec_dir, args.pocket)

    # ── 4. Ligand loop ─────────────────────────────────────────────────────
    results: List[Dict] = []

    for idx, (spec, hint) in enumerate(zip(LIGANDS, names), start=1):
        log.info("══ Ligand %d/%d ══════════════════════════════════════",
                 idx, len(LIGANDS))

        try:
            # 4a. Prepare ligand PDBQT
            name, ligand_pdbqt = prepare_ligand(spec, idx, hint, ligands_dir)

            # 4b. Per-ligand sub-directories
            lig_poses_dir = out_dir / "poses" / name
            lig_logs_dir  = out_dir / "logs"  / name
            lig_poses_dir.mkdir(parents=True, exist_ok=True)
            lig_logs_dir.mkdir(parents=True, exist_ok=True)

            # 4c. Multi-run docking
            result = multi_run_dock(
                rigid_pdbqt, flex_pdbqt, ligand_pdbqt, name,
                lig_poses_dir, lig_logs_dir, center, size,
            )
            results.append(result)

        except Exception as exc:
            log.error("  FAILED: %s — %s", type(exc).__name__, exc)
            results.append({
                "name":           hint or f"ligand_{idx:03d}",
                "best_affinity":  float("nan"),
                "ki_uM":          float("nan"),
                "classification": "ERROR",
                "rmsd_lb":        float("nan"),
                "rmsd_ub":        float("nan"),
                "num_modes":      0,
                "all_modes":      [],
                "runs":           NUM_RUNS,
                "exhaustiveness_used": EXHAUSTIVENESS,
                "error":          str(exc),
            })

    # ── 5. Summary ─────────────────────────────────────────────────────────
    log.info("══ Summary ═══════════════════════════════════════════")
    if results:
        write_summary(results, summary_dir, center, size)

    ok  = [r for r in results if r.get("num_modes", 0) > 0]
    err = [r for r in results if r.get("num_modes", 0) == 0]

    log.info("Done: %d succeeded  |  %d failed", len(ok), len(err))
    if ok:
        best = min(ok, key=lambda r: r["best_affinity"])
        log.info("Best binder: %s  ΔG=%.3f kcal/mol  Ki≈%.4f µM  [%s]",
                 best["name"], best["best_affinity"],
                 best["ki_uM"], best["classification"])
    log.info("All output in: %s", out_dir.resolve())

    return 0 if not err else 2


if __name__ == "__main__":
    sys.exit(main())
