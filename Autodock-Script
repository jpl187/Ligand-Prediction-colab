def _run(cmd: List[str], *, check: bool = True,
         capture: bool = False, cwd: Optional[Path] = None) -> subprocess.CompletedProcess:
    log.debug("$ %s", " ".join(str(c) for c in cmd))
    return subprocess.run(cmd, check=check, capture_output=capture,
                          text=True, cwd=cwd)


def _is_cmd(name: str) -> bool:
    return shutil.which(name) is not None


def _is_smiles(s: str) -> bool:
    p = Path(s)
    if p.suffix.lower() in (".sdf", ".mol", ".mol2", ".pdb", ".pdbqt", ".xyz", ".pqr"):
        return False
    if p.exists():
        return False
    return True


